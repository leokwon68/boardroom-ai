# Copy this file to ".env.local" (same folder) and fill in your values.
# .env.local is gitignored — secrets never get committed or printed.
# Notarization uses your Apple ID + an app-specific password.

# Your Apple ID email (the developer account)
APPLE_ID=you@example.com

# App-specific password — make one at https://appleid.apple.com
#   → Sign-In and Security → App-Specific Passwords → "+"
# Looks like: abcd-efgh-ijkl-mnop
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your Team ID (already known from your Distribution cert)
APPLE_TEAM_ID=Q8H5FX7D7Z
